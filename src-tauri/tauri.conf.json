{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlitterAmp",
  "version": "0.1.0",
  "identifier": "org.blitteramp.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BlitterAmp",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/blitterserver"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxOUZGRENDNjBFNkREQkUKUldTKzNlWmd6UDJmMGJkdEdVbXNvazIzVEdFRGkyK1hCUE9JdlorTk5lbjNua2J4STBodWZLeVoK",
      "endpoints": [
        "https://github.com/BlitterAmp/BlitterAmp/releases/latest/download/latest.json"
      ]
    }
  }
}