{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "store:default",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "blitterserver",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://127.0.0.1:*"
        },
        {
          "url": "http://localhost:*"
        },
        {
          "url": "http://*:*"
        },
        {
          "url": "https://*:*"
        },
        {
          "url": "http://*"
        },
        {
          "url": "https://*"
        }
      ]
    }
  ]
}